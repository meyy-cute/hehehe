local function parseTimeFromString(str)
    local h, m, s = string.match(str, "(%d+):(%d+):(%d+)")
    if h and m and s then
        return (tonumber(h) * 3600) + (tonumber(m) * 60) + tonumber(s)
    end
    return 0
end

