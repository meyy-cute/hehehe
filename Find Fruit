end

local function _tp(aL)
    local result = true
    pcall(function()
        local character = plr and plr.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not (character and humanoid and rootPart and humanoid.Health > 0) then result = false return end

        if humanoid.Sit then humanoid.Sit = false end

        if getgenv().activeTween then
            pcall(function() getgenv().activeTween:Cancel() end)
            getgenv().activeTween = nil
        end

        local targetPos = aL.Position
        local Distance = (targetPos - rootPart.Position).Magnitude

        if Distance <= 10 then
            rootPart.CFrame = aL
            return
        end

        local DefaultY = aL.Position.Y
        local tweenDuration = Distance / TWEEN_SPEED
        local tweenInfo = TweenInfo.new(tweenDuration, Enum.EasingStyle.Linear)

        getgenv().activeTween = TweenService:Create(rootPart, tweenInfo, { CFrame = aL })
        getgenv().activeTween:Play()
        
        local tweenStart = tick()
        while getgenv().activeTween and getgenv().activeTween.PlaybackState == Enum.PlaybackState.Playing do
            task.wait(0.1)
            if tick() - tweenStart > 120 then
                getgenv().activeTween:Cancel()
                getgenv().activeTween = nil
                result = "Timeout"
                return
            end
        end
        
        if rootPart then rootPart.CFrame = aL end
        getgenv().activeTween = nil
    end)
    return result
end

local function PickupFruit(fruitModel)
    local handle = fruitModel:FindFirstChild("Handle")
    if not handle then return false end
    
    getgenv().CurrentFruitTargetPos = handle
    _G.SetFruitStatus("Moving to Fruit...")

    local rootPart = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end

    print("[Fruit] Đang tween đến: " .. GetFruitName(fruitModel))
    local tpStatus = _tp(CFrame.new(handle.Position))
    
    if tpStatus == "Timeout" then
        print("[Fruit] Timeout khi di chuyển (quá 3 phút)")
        return "Timeout"
    elseif tpStatus == false then
        return false
    end

    task.wait(0.5)

    local picked = false

    pcall(function()
        firetouchinterest(rootPart, handle, 0)
        task.wait(0.1)
        firetouchinterest(rootPart, handle, 1)
        picked = true
    end)
    if not picked then
        pcall(function()
            for _, pp in pairs(handle:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then
                    fireproximityprompt(pp)
                    picked = true
                end
            end
        end)
    end
    if not picked then
        pcall(function()
            for _, cd in pairs(handle:GetDescendants()) do
                if cd:IsA("ClickDetector") then
                    fireclickdetector(cd)
                    picked = true
                end
            end
        end)
    end
    if not picked then
        pcall(function()
            local eatRemote = fruitModel:FindFirstChild("EatRemote", true)
            if eatRemote then
                eatRemote:InvokeServer("Pickup")
                picked = true
            end
        end)
    end

    return picked
end

local function HopToFruitServer()
    _G.SetFruitStatus("Hopping to new server...")
    _G.SetFruitTarget("None")
    getgenv().CurrentFruitTargetPos = nil
    
    local apiUrl = 'http://chiucacemroiii.x10.network/api.php?api=Fruits'
    local CURRENT_PLACE_ID = game.PlaceId

    if tick() - getgenv().LastApiRefresh > 600 then
        getgenv().FailedJobIds = {}
        getgenv().LastApiRefresh = tick()
    end

    local ok, result = pcall(function()
        local responseBody
        pcall(function() responseBody = game:HttpGet(apiUrl) end)
        if not responseBody or responseBody == "" then
            local reqFunc = (syn and syn.request) or request or http_request
            if reqFunc then
                local req = reqFunc({ Url = apiUrl, Method = "GET" })
                responseBody = req and req.Body
            end
        end
        if not responseBody then
            print("[Hop] Không lấy được API")
            return false
        end

        local data = HttpService:JSONDecode(responseBody)
        if not data or not data.success or type(data.data) ~= "table" then
            print("[Hop] API data sai")
            return false
        end

        local seen = {}
        local filtered = {}
        for _, entry in ipairs(data.data) do
            local jobId = entry.jobid
            local placeId = tonumber(entry.placeid)
            local players = tonumber(entry.player) or 99

            if jobId 
            and placeId == CURRENT_PLACE_ID
            and jobId ~= game.JobId
            and not seen[jobId]
            and not getgenv().FailedJobIds[jobId]
            and players < MAX_PLAYERS then
                seen[jobId] = true
                table.insert(filtered, { jobid = jobId, players = players })
            end
        end

        table.sort(filtered, function(a, b) return a.players < b.players end)
        print("[Hop] Tìm thấy " .. #filtered .. " server có fruit")

        if #filtered == 0 then
            print("[Hop] Không có server | Đợi " .. WAIT_TIME .. "s...")
            task.wait(WAIT_TIME)
            return false
        end

        for _, server in ipairs(filtered) do
            local jobId = server.jobid
            print("[Hop] Join server: " .. jobId .. " | " .. server.players .. " người")

            local teleportOk = pcall(function()
                game:GetService("ReplicatedStorage"):WaitForChild("__ServerBrowser"):InvokeServer("teleport", jobId)
            end)

            if teleportOk then
                task.wait(20)
                getgenv().FailedJobIds[jobId] = tick()
            else
                getgenv().FailedJobIds[jobId] = tick()
                task.wait(1)
            end
        end

        task.wait(WAIT_TIME)
        return false
    end)

    if not ok then print("[Hop] Lỗi: " .. tostring(result)) end
end

