local baseRotX, baseRotY = 0, 0
RunService.RenderStepped:Connect(function(dt)
    local tickTime = tick()
    
    for _, grad in ipairs(UI_Elements.Strokes) do
        if grad and grad.Parent then
            grad.Rotation = (grad.Rotation + dt * 40) % 360
        end
    end
    
    for _, grad in ipairs(UI_Elements.Texts) do
        if grad and grad.Parent then
            grad.Offset = Vector2.new(math.sin(tickTime * 2) * 0.5, 0)
        end
    end
    
    for _, pulse in ipairs(UI_Elements.Pulses) do
        if pulse and pulse.Parent then
            local pScale = 1 + math.abs(math.sin(tickTime * 3)) * 0.4
            pulse.Size = UDim2.new(pScale, 0, pScale, 0)
            pulse.BackgroundTransparency = 0.5 + math.abs(math.sin(tickTime * 3)) * 0.5
        end
    end
    
    if minimized and Mini3DContainer.Visible then
        baseRotX = baseRotX + dt * 1.5
        baseRotY = baseRotY + dt * 2.0
        
        local cx, sx = math.cos(baseRotX), math.sin(baseRotX)
        local cy, sy = math.cos(baseRotY), math.sin(baseRotY)
        local cz, sz = math.cos(baseRotX * 0.5), math.sin(baseRotX * 0.5)
        
        local proj2D = {}
        for i, v in ipairs(cubeVertices) do
            local x1 = v.X * cy - v.Z * sy
            local z1 = v.Z * cy + v.X * sy
            
            local y2 = v.Y * cx - z1 * sx
            local z2 = z1 * cx + v.Y * sx
            
            local x3 = x1 * cz - y2 * sz
            local y3 = y2 * cz + x1 * sz
            
            local fov = 15
            local scale = fov / (fov + z2 + 3)
            
            local px = x3 * scale * 15
            local py = y3 * scale * 15
            
            proj2D[i] = Vector2.new(px, py)
        end
        
        for i, edge in ipairs(cubeEdges) do
            local p1 = proj2D[edge[1]]
            local p2 = proj2D[edge[2]]
            local line = edgeLines[i]
            if line then
                local dist = (p2 - p1).Magnitude
                local center = (p1 + p2) / 2
                local angle = math.atan2(p2.Y - p1.Y, p2.X - p1.X)
                
                line.Size = UDim2.new(0, dist, 0, 1.5)
                line.Position = UDim2.new(0.5, center.X, 0.5, center.Y)
                line.Rotation = math.deg(angle)
            end
        end
    end
end)

