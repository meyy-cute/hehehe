local function CountNumber(label, targetValue)
    local val = Instance.new("NumberValue")
    val.Value = 0
    val.Changed:Connect(function(v)
        label.Text = tostring(math.floor(v))
    end)
    local tw = TweenService:Create(val, TweenInfo.new(2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Value = targetValue})
    tw:Play()
end

