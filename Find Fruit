local function GetFruitName(v)
    local attrs = {"Name", "FruitName", "OriginalName", "ItemName"}
    for _, attr in ipairs(attrs) do
        local val = v:GetAttribute(attr)
        if val and val ~= "" and val ~= "Fruit" then
            return val
        end
    end
    if v:FindFirstChild("Handle") then
        for _, c in pairs(v.Handle:GetChildren()) do
            if c:IsA("StringValue") and c.Value ~= "" then
                return c.Value
            end
        end
    end
    if v.Name ~= "Fruit" and v.Name ~= "" then
        return v.Name
    end
    return "Unknown Fruit"
end

local function GetFruitsInServer()
    local fruits = {}
