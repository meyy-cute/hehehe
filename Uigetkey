local function ApplyButtonEffects(btn)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, btn.Size.Y.Scale, btn.Size.Y.Offset + 2), BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset, btn.Size.Y.Scale, btn.Size.Y.Offset - 2), BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
    end)
    
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn.UITransform or Instance.new("UITransform", btn), TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 0.8}):Play()
    end)
    
    btn.MouseButton1Up:Connect(function()
        local t1 = TweenService:Create(btn.UITransform or btn:FindFirstChild("UITransform"), TweenInfo.new(0.2, Enum.EasingStyle.Bounce), {Scale = 1.1})
        t1:Play()
        t1.Completed:Connect(function()
            TweenService:Create(btn.UITransform or btn:FindFirstChild("UITransform"), TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 1}):Play()
        end)
    end)
end

for _, btn in pairs(UI_Elements.Buttons) do
    local transform = Instance.new("UITransform")
    transform.Parent = btn
    ApplyButtonEffects(btn)
end

