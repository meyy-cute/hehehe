local function SetupCopyLogic(btn, linkStr)
    btn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(linkStr)
            local oldText = btn.Text
            btn.Text = "COPIED TO CLIPBOARD"
            btn.TextColor3 = Color3.fromHex("#8C64FF") 
            local grad = btn:FindFirstChildWhichIsA("UIGradient")
            if grad then grad.Enabled = false end
            
            task.delay(1.5, function()
                btn.Text = oldText
                btn.TextColor3 = DarkTheme.TextColor
                if grad then grad.Enabled = true end
            end)
        else
            btn.Text = "NOT SUPPORTED"
            task.delay(1.5, function() btn.Text = btn.Name end)
        end
    end)
end

