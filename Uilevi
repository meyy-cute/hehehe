task.spawn(function()
    while task.wait(1) do
        pcall(function()
            if typeof(CheckLeviathan) == "function" then
                _G.KaituUI.SetLeviStatus(CheckLeviathan())
            end
            if typeof(CheckFrozenDimension) == "function" then
                _G.KaituUI.SetFrozenStatus(CheckFrozenDimension())
            end
            if typeof(CheckBoat) == "function" and typeof(CountHelpersOnBoat) == "function" then
                local boat = CheckBoat()
                local cur = boat and CountHelpersOnBoat(boat) or 0
                local req = typeof(GetRequiredHelpers) == "function" and GetRequiredHelpers() or 1
                _G.KaituUI.SetHelpers(cur, req)
            end
        end)
    end
end)

