local function GridCard(label, value, sub, order)
    local card = Instance.new("Frame")
    card.BackgroundColor3 = Themes.ContainerBg
    card.BackgroundTransparency = Themes.GlassTransparency
    card.BorderSizePixel = 0
    card.LayoutOrder = order
    card.Parent = gridFrame

    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 8)
    cardCorner.Parent = card

    local cardStroke = Instance.new("UIStroke")
    cardStroke.Color = Color3.new(1,1,1)
    cardStroke.Thickness = Themes.InnerStrokeThickness
    cardStroke.Parent = card
    
    local cardStrokeGrad = Instance.new("UIGradient")
    cardStrokeGrad.Color = Themes.GradientOcean
    cardStrokeGrad.Parent = cardStroke
    table.insert(UI_Elements.Strokes, cardStrokeGrad)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -16, 0, 14)
    lbl.Position = UDim2.new(0, 8, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(130, 130, 160)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 10
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = card

    local valL = Instance.new("TextLabel")
    valL.Size = UDim2.new(1, -16, 0, 18)
    valL.Position = UDim2.new(0, 8, 0, 24)
    valL.BackgroundTransparency = 1
    valL.Text = value
    valL.TextColor3 = Themes.TextWhite
    valL.Font = Enum.Font.GothamBold
    valL.TextSize = 13
    valL.TextXAlignment = Enum.TextXAlignment.Left
    valL.Parent = card
    
    local valLGrad = Instance.new("UIGradient")
    valLGrad.Color = Themes.GradientOcean
    valLGrad.Rotation = 90
    valLGrad.Parent = valL
    table.insert(UI_Elements.Texts, valLGrad)

    local subL = Instance.new("TextLabel")
    subL.Size = UDim2.new(1, -16, 0, 12)
    subL.Position = UDim2.new(0, 8, 0, 44)
    subL.BackgroundTransparency = 1
    subL.Text = sub
    subL.TextColor3 = Color3.fromRGB(100, 100, 130)
    subL.Font = Enum.Font.Gotham
    subL.TextSize = 10
    subL.TextXAlignment = Enum.TextXAlignment.Left
    subL.Parent = card

    return valL, valLGrad
end

