local function FindTargetBoat(ownerName)
    local BoatsFolder = workspace:FindFirstChild("Boats")
    if not BoatsFolder then return nil end
    for _, boat in pairs(BoatsFolder:GetChildren()) do
        if boat:IsA("Model") and boat:FindFirstChild("Owner") then
            local owner = boat.Owner.Value
            if owner and owner.Name == ownerName then return boat end
        end
    end
    return nil
end

local function FindEmptySeatOnBoat(boat)
    if not boat then return nil end
    local allSeats = {}
    for _, part in pairs(boat:GetDescendants()) do
        if (part:IsA("Seat") or part:IsA("VehicleSeat")) and part.Name ~= "VehicleSeat" then
            table.insert(allSeats, part)
        end
    end
    for _, seat in pairs(allSeats) do
        if seat.Occupant == nil then return seat end
    end
    return boat:FindFirstChild("Deck") or boat:FindFirstChild("Base") or boat.PrimaryPart
end

