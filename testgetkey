local function saveKey(key)
    local suc, err = pcall(function()
        local path = MeyyHub.saveFile
        local dir = path:match("^(.*/)")
        if dir then
            pcall(function() makefolder(dir) end)
        end
        writefile(path, key)
    end)
    return suc
end

local function loadKey()
    local suc, key = pcall(function()
        return readfile(MeyyHub.saveFile)
    end)
    if suc and key and key ~= "" then
        return key
    end
    return nil
end

local function deleteKey()
    pcall(function()
        delfile(MeyyHub.saveFile)
    end)
end

