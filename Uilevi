_G.KaituUI = {}

_G.KaituUI.SetMainTask = function(text)
    mainTaskVal.Text = text or "n/a"
end

_G.KaituUI.SetScriptStatus = function(text, isError)
    scriptStatusVal.Text = text or "idle"
    if isError then
        scriptStatusGrad.Color = Themes.GradientStatusAlert
    else
        scriptStatusGrad.Color = Themes.GradientStatusActive
    end
end

_G.KaituUI.SetLeviStatus = function(found)
    if found then
        leviDotGrad.Color = Themes.GradientStatusActive
        leviVal.Text = "found!"
        leviValGrad.Color = Themes.GradientStatusActive
    else
        leviDotGrad.Color = Themes.GradientStatusAlert
        leviVal.Text = "not yet"
        leviValGrad.Color = Themes.GradientOcean
    end
end

_G.KaituUI.SetFrozenStatus = function(found)
    if found then
        frozenDotGrad.Color = Themes.GradientStatusAlert
        frozenVal.Text = "DETECTED"
        frozenValGrad.Color = Themes.GradientStatusAlert
    else
        frozenDotGrad.Color = Themes.GradientStatusActive
        frozenVal.Text = "clear"
        frozenValGrad.Color = Themes.GradientStatusActive
    end
end

_G.KaituUI.SetHelpers = function(current, required)
    local ready = current >= required
    helpersDotGrad.Color = ready and Themes.GradientStatusActive or Themes.GradientStatusWarning
    helpersVal.Text = current .. " / " .. required
    helpersValGrad.Color = ready and Themes.GradientStatusActive or Themes.GradientStatusWarning

    if ready then
        helperBadgeStroke.Color = Themes.GradientStatusActive
        helperBadgeL.Text = "on boat"
        helperBadgeLGrad.Color = Themes.GradientStatusActive
    else
        helperBadgeStroke.Color = Themes.GradientStatusWarning
        helperBadgeL.Text = "waiting"
        helperBadgeLGrad.Color = Themes.GradientStatusWarning
    end
end

_G.KaituUI.SetHeaderStatus = function(text, isActive)
    StatusBadgeText.Text = text or "idle"
    if isActive then
        StatusBadgeGrad.Color = Themes.GradientStatusActive
        StatusTextGrad.Color = Themes.GradientStatusActive
    else
        StatusBadgeGrad.Color = Themes.GradientOcean
        StatusTextGrad.Color = Themes.GradientOcean
    end
end

