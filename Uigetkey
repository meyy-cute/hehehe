local function CreateButton(name, text, layoutOrder)
	local ButtonFrame = Instance.new("Frame")
	ButtonFrame.Name = name .. "Wrapper"
	ButtonFrame.Size = UDim2.new(0, 132, 0, 35)
	ButtonFrame.BackgroundTransparency = 1
	ButtonFrame.LayoutOrder = layoutOrder
	ButtonFrame.Parent = ButtonContainer

	local Scale = Instance.new("UIScale")
	Scale.Parent = ButtonFrame

	local Button = Instance.new("TextButton")
	Button.Name = name
	Button.Size = UDim2.new(1, 0, 1, 0)
	Button.BackgroundColor3 = Themes.Background
	Button.BackgroundTransparency = 0.2
	Button.BorderSizePixel = 0
	Button.Text = text
	Button.Font = Enum.Font.GothamBold
	Button.TextSize = 12
	Button.TextColor3 = Themes.TextMain
	Button.Parent = ButtonFrame

	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 6)
	BtnCorner.Parent = Button

	local BtnStroke = Instance.new("UIStroke")
	BtnStroke.Thickness = 1
	BtnStroke.Color = Themes.AccentDark
	BtnStroke.Parent = Button

	Button.MouseEnter:Connect(function()
		TweenService:Create(Scale, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 1.05}):Play()
		TweenService:Create(Button, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {BackgroundColor3 = Themes.Active}):Play()
	end)

	Button.MouseLeave:Connect(function()
		TweenService:Create(Scale, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 1}):Play()
		TweenService:Create(Button, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {BackgroundColor3 = Themes.Background}):Play()
	end)

	Button.MouseButton1Down:Connect(function()
		TweenService:Create(Scale, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 0.8}):Play()
	end)

	Button.MouseButton1Click:Connect(function()
		TweenService:Create(Scale, TweenInfo.new(0.1, Enum.EasingStyle.Bounce), {Scale = 1.3}):Play()
		task.wait(0.1)
		TweenService:Create(Scale, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 1}):Play()
	end)

	return Button
end

