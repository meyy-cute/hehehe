VerifyBtn.MouseButton1Click:Connect(function()
	local enteredKey = TextBox.Text
	if enteredKey == "" then
		UpdateStatus("Please enter a valid key!", Color3.fromRGB(200, 50, 50))
	elseif enteredKey == "meyy_demo_key_2026" then
		UpdateStatus("Key validated! Loading meyy hub...", Color3.fromRGB(50, 200, 50))
		task.wait(1)
		
		TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingStyle.Out), {
			Position = UDim2.new(0.5, -180, 1, 50),
			BackgroundTransparency = 1
		}):Play()
		
		task.wait(0.4)
		KeyAuthUI:Destroy()
		
	else
		UpdateStatus("Invalid or expired key!", Color3.fromRGB(200, 50, 50))
	end
end)
