ListLayout.VerticalAlignment = Enum.VerticalAlignment.Center

local function CreateRowFrame(order)
    local row = Instance.new("Frame", MainFrame)
    row.Size = UDim2.new(1, -16, 0, 20)
    row.BackgroundTransparency = 1
    row.LayoutOrder = order
    return row
end

local function CreateStatusLabel(name, defaultText, parent, anchor, pos, align)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Name = name
    lbl.Size = UDim2.new(0.5, -2, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 11
    lbl.TextColor3 = DarkTheme.TextColor
    lbl.Text = defaultText
    lbl.AnchorPoint = anchor
    lbl.Position = pos
    lbl.TextXAlignment = align
    
    local grad = Instance.new("UIGradient", lbl)
    grad.Rotation = 90
    grad.Color = DarkTheme.TextGrad
    
    local shadow = Instance.new("UIStroke", lbl)
    shadow.Color = Color3.fromHex("#888888")
    shadow.Thickness = 0.2
    shadow.Transparency = 0.5
    
    return lbl
end

