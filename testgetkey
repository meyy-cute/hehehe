local function CreateButton(name, text, parent, size, pos)
    local btn = Instance.new("TextButton", parent)
    btn.Name = name
    btn.Size = size
    btn.Position = pos
    btn.BackgroundColor3 = DarkTheme.ContainerBg
    btn.BackgroundTransparency = DarkTheme.ContainerTrans
    btn.Font = Enum.Font.GothamBold
    btn.Text = text
    btn.TextSize = 13
    btn.AutoButtonColor = false
    ApplyTextGradient(btn)
    
    local corner = Instance.new("UICorner", btn)
    corner.CornerRadius = UDim.new(0, 8)
    
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = DarkTheme.MainStroke
    stroke.Thickness = 1.2
    
    local grad = Instance.new("UIGradient", stroke)
    grad.Color = DarkTheme.LoopSeq
    table.insert(UI_Elements.RotatingGradients, grad)
    
    local scale = Instance.new("UIScale", btn)
    scale.Scale = 1
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundTransparency = 0.2}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundTransparency = DarkTheme.ContainerTrans}):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(scale, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Scale = 0.9}):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(scale, TweenInfo.new(0.3, Enum.EasingStyle.Bounce), {Scale = 1}):Play()
    end)
    
    return btn
end

