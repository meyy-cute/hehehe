RunService.RenderStepped:Connect(function(dt)
    local timeTick = tick()
    
    for _, grad in ipairs(RotatingGradients) do
        grad.Rotation = (timeTick * 100) % 360
    end
    
    for _, rp in ipairs(RippleElements) do
        local scale = math.abs(math.sin(timeTick * 3))
        rp.Ring.Size = UDim2.new(1 + scale, 0, 1 + scale, 0)
        rp.Ring.Position = UDim2.new(0.5, -(rp.Ring.Size.X.Offset/2), 0.5, -(rp.Ring.Size.Y.Offset/2))
        rp.Ring.BackgroundTransparency = 0.5 + (scale * 0.5)
        
        if rp.HasItem then
            rp.Ring.BackgroundColor3 = CurrentTheme.Highlight
        else
            rp.Ring.BackgroundColor3 = CurrentTheme.DimText
        end
    end
end)

