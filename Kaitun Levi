local function CountHelpersOnBoat(boat)
    if not boat then return 0 end
    local count = 0
    for _, part in pairs(boat:GetDescendants()) do
        if (part:IsA("Seat") or part:IsA("VehicleSeat")) and part.Occupant then
            local character = part.Occupant.Parent
            local player = game.Players:GetPlayerFromCharacter(character)
            if player then
                for _, helperName in pairs(CFG["Account Help"]) do
                    if player.Name == helperName then count = count + 1; break end
                end
            end
        end
    end
    return count
end

local function GetRequiredHelpers()
    return #CFG["Account Help"]
end

