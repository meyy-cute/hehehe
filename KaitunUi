local IsUIOpen = true
local IsUIMini = false

local function ToggleMainUI()
    IsUIOpen = not IsUIOpen
    if IsUIOpen then
        MainUI.Visible = true
        TweenService:Create(MainUI, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -275, 0.5, -160)}):Play()
        for i, frame in ipairs(ItemFrames) do
            frame.Position = UDim2.new(0, 50, 0, 0)
            frame.BackgroundTransparency = 1
            TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
            task.wait(0.05)
        end
        CountNumber(LevelVal, 2550)
        CountNumber(BeliVal, 15000000)
        CountNumber(FragVal, 50000)
    else
        local tw = TweenService:Create(MainUI, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(0.5, -275, 1.5, 0)})
        tw:Play()
        tw.Completed:Connect(function()
            if not IsUIOpen then MainUI.Visible = false end
        end)
    end
end

