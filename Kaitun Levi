                for a, b in pairs(workspace.SeaBeasts:GetChildren()) do
                    if b:FindFirstChild("HumanoidRootPart") and b:FindFirstChild("Leviathan Segment") and b:FindFirstChild("Health") and b.Health.Value > 0 then
                        repeat
                            task.wait()
                            spawn(function()
                                _tp(CFrame.new(b.HumanoidRootPart.Position.X, game:GetService("Workspace").Map["WaterBase-Plane"].Position.Y + 200, b.HumanoidRootPart.Position.Z))
                            end)
                            if plr:DistanceFromCharacter(b.HumanoidRootPart.CFrame.Position) <= 500 then
                                if CheckF() then
                                    if MelleeSkills["Enable"] then
                                        if MelleeSkills["Skill"]["Z"]["Enable"] then 
                                            wait(MelleeSkills["Skill"]["Z"]["HoldTime"])
                                            Useskills("Melee", "Z")
                                        end
                                        if MelleeSkills["Skill"]["X"]["Enable"] then
                                            wait(MelleeSkills["Skill"]["X"]["HoldTime"])
                                            Useskills("Melee", "X")
                                        end
                                        if MelleeSkills["Skill"]["C"]["Enable"] then
                                            wait(MelleeSkills["Skill"]["C"]["HoldTime"])
                                            Useskills("Melee", "C")
                                        end
                                    end
                                    if BloxFruitSkills["Enable"] then
                                        if BloxFruitSkills["Skills"]["Z"]["Enable"] then
                                            wait(BloxFruitSkills["Skills"]["Z"]["HoldTime"])
                                            Useskills("Blox Fruit", "Z")
                                        end
                                        if BloxFruitSkills["Skills"]["X"]["Enable"] then
                                            wait(BloxFruitSkills["Skills"]["X"]["HoldTime"])
                                            Useskills("Blox Fruit", "X")
                                        end
                                        if BloxFruitSkills["Skills"]["C"]["Enable"] then
                                            wait(BloxFruitSkills["Skills"]["C"]["HoldTime"])
                                            Useskills("Blox Fruit", "C")
                                        end
                                        if BloxFruitSkills["Skills"]["V"]["Enable"] then
                                            wait(BloxFruitSkills["Skills"]["V"]["HoldTime"])
                                            Useskills("Blox Fruit", "V")
                                        end
                                        if BloxFruitSkills["Skills"]["F"]["Enable"] then
                                            wait(BloxFruitSkills["Skills"]["F"]["HoldTime"])
                                            Useskills("Blox Fruit", "F")
                                        end
                                    end
                                    if GunSkills["Enable"] then
                                        if GunSkills["Skills"]["Z"]["Enable"] then
                                            wait(GunSkills["Skills"]["Z"]["HoldTime"])
                                            Useskills("Gun", "Z")
                                        end
                                        if GunSkills["Skills"]["X"]["Enable"] then
                                            wait(GunSkills["Skills"]["X"]["HoldTime"])
                                            Useskills("Gun", "X")
                                        end
                                    end
                                    if SwordSkills["Enable"] then
                                        if SwordSkills["Skills"]["Z"]["Enable"] then
                                            wait(SwordSkills["Skills"]["Z"]["HoldTime"])
                                            Useskills("Sword", "Z")
                                        end
                                        if SwordSkills["Skills"]["X"]["Enable"] then
                                            wait(SwordSkills["Skills"]["X"]["HoldTime"])
                                            Useskills("Sword", "X")
                                        end
                                    end
                                else
                                    SetStatus("Your Config doesn't have any skill enable to attack levi")
                                end
                            end
                        until _G.AttackLevi == false or not b:FindFirstChild("HumanoidRootPart") or not b.Parent or b.Health.Value <= 0
                    end
                end
            end
        end
    end
end

local function main()
    wait(2)
    local playerName = plr.Name
    local isOwner = (playerName == CFG["Owner Boat"])
    local isHelper = false
    for _, name in pairs(CFG["Account Help"]) do
        if playerName == name then
            isHelper = true
            break
        end
    end
    if isOwner then
        SetStatus("Finding Leviathan...")
        _G.SailBoats = true
        FindLevi()
    elseif isHelper then
        SetStatus("Follow owner boat...")
        _G.TweenBoatPlr = true
    else
        SetStatus("Not in config list!")
    end
end

main()
SetKaitunStatus("done")
