local function CountHelpersOnBoat(boat)
    if not boat then return 0 end
    local count = 0
    local helperNames = CFG["Account Help"]
    for _, part in pairs(boat:GetDescendants()) do
        if (part:IsA("Seat") or part:IsA("VehicleSeat")) and part.Occupant then
            local humanoid = part.Occupant
            local character = humanoid.Parent
            local player = game.Players:GetPlayerFromCharacter(character)
            if player then
                for _, helperName in pairs(helperNames) do
                    if player.Name == helperName then
                        count = count + 1
                        break
                    end
                end
            end
        end
    end
    return count
end

